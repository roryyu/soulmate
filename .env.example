# Environment variables declared in this file are available at build-time and runtime.
# Copy this file to .env.local and update with your actual values.

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Prisma 连接池（云函数/多并发同一实例时缓解 P2024；总连接约 ≈ 并发实例数 × PRISMA_CONNECTION_LIMIT）
# PRISMA_CONNECTION_LIMIT="3"
# PRISMA_POOL_TIMEOUT="20"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# AI Provider Configuration
# Supported providers: deepseek (default), ark (ByteDance Volcano Engine)
AI_PROVIDER="deepseek"

# DeepSeek Configuration (when AI_PROVIDER=deepseek)
AI_API_KEY="your-deepseek-api-key"
AI_BASE_URL="https://api.deepseek.com/v1"
AI_MODEL="deepseek-chat"

# ByteDance Volcano Engine ARK Configuration (when AI_PROVIDER=ark)
ARK_API_KEY="your-ark-api-key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_MODEL="doubao-pro-32k-2411"
# Embedding 模型配置
ARK_TEXT_EMBEDDING_MODEL="doubao-embedding-text-250615"
ARK_EMBEDDING_MODEL="doubao-embedding-vision-250615"

# ByteDance Volcano Engine TOS (Object Storage) Configuration
TOS_ACCESS_KEY="your-tos-access-key"
TOS_SECRET_KEY="your-tos-secret-key"
TOS_REGION="cn-beijing"
TOS_ENDPOINT="tos-cn-beijing.volces.com"
TOS_BUCKET="edu-nexus"

# Alibaba Cloud OSS Configuration
OSS_ACCESS_KEY="your-oss-access-key"
OSS_SECRET_KEY="your-oss-secret-key"
OSS_REGION="oss-cn-shanghai"
OSS_BUCKET=""

# ByteDance Volcano Engine Visual API Configuration (PDF/Image OCR)
# Used for parsing PDF and image documents
VISUAL_ACCESS_KEY_ID="your-visual-access-key-id"
VISUAL_ACCESS_KEY_SECRET="your-visual-access-key-secret"
VISUAL_REGION="cn-north-1"

# Volcano SMS Configuration (SendSms API)
# 火山引擎短信服务配置，用于手机号验证码登录/注册
# 文档: https://www.volcengine.com/docs/sms
VOLCANO_SMS_ACCESS_KEY_ID=""        # 你的 AccessKey ID
VOLCANO_SMS_ACCESS_KEY_SECRET=""    # 你的 Secret Access Key
VOLCANO_SMS_ACCOUNT=""              # 你的消息组ID (短信控制台获取)
VOLCANO_SMS_SIGN="Soulmates"           # 审核通过的短信签名
VOLCANO_SMS_TEMPLATE_ID=""          # 审核通过的模板ID

# Alipay Configuration
# 支付宝应用ID（沙箱环境：9021000162652029）
ALIPAY_APP_ID=""
# 应用私钥（PKCS1格式，去掉-----BEGIN PRIVATE KEY-----和-----END PRIVATE KEY-----）
ALIPAY_PRIVATE_KEY=""
# 支付宝公钥（PKCS1格式，去掉-----BEGIN PUBLIC KEY-----和-----END PUBLIC KEY-----）
ALIPAY_PUBLIC_KEY=""
# 支付宝网关（沙箱环境：https://openapi-sandbox.dl.alipaydev.com/gateway.do，正式环境：https://openapi.alipay.com/gateway.do）
ALIPAY_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"

# Minimax Configuration (Music Generation)
# 用于音乐生成功能
MINIMAX_API_KEY=""